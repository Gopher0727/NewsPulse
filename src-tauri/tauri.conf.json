{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "newspulse",
  "version": "0.1.0",
  "identifier": "com.gopher0727.newspulse.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NewsPulse",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}